    "react-dom": "^19.2.6",
    "react-hook-form": "^7.78.0",
    "react-leaflet": "^5.0.0",
    "swiper": "^12.2.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
